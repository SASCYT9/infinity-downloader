# Local-network setup. Copy this to .env.local and adjust your LAN IP.
# .env.local is gitignored, so your settings stay on your machine.

# LAN IP of the host running Cobalt + Next.js. Find with `ipconfig` (Windows)
# or `ifconfig` / `ip addr` (Linux/macOS). Common ranges: 192.168.x.x or 10.x.x.x.
LAN_IP=192.168.50.157

# Self-hosted Cobalt. Used by the Next.js API route on the server side.
# localhost works because Next.js and Cobalt run on the same machine.
COBALT_INSTANCE_URL=http://localhost:9000

# Cobalt's externally-visible URL — phones must be able to reach this. This is
# what gets baked into tunnel URLs. Match LAN_IP above.
COBALT_API_URL=http://192.168.50.157:9000/

# Public-facing settings.
# Empty / unset means the Vercel "online" path is used and the local engine
# disabled. Local-only setup doesn't need them.
NEXT_PUBLIC_API_URL=
NEXT_PUBLIC_USE_LOCAL_ENGINE=false
